component TabButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked;

    width: 172px;
    height: 34px;
    border-radius: 6px;
    border-width: 1px;
    border-color: selected ? #0284c7 : #00000000;
    background: selected ? #0c4a6e : #00000000;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.selected ? #f0f9ff : #b8c5d8;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked();
        }
    }
}

component MetricTile inherits Rectangle {
    in property <string> label;
    in property <string> value;

    min-width: 170px;
    min-height: 66px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #273449;
    background: #101827;

    VerticalLayout {
        padding: 10px;
        spacing: 6px;
        Text { text: root.label; color: #9ca9bd; font-size: 12px; }
        Text { text: root.value; color: #f4f7fb; font-size: 15px; wrap: word-wrap; }
    }
}

component ActionButton inherits Rectangle {
    in property <string> label;

    width: 128px;
    height: 34px;
    border-radius: 6px;
    border-width: 1px;
    border-color: #3c4c66;
    background: #111c2e;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f4f7fb;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component PageContent inherits Rectangle {
    in property <string> heading;
    in property <string> summary;
    in property <string> status;
    in property <string> primary;
    in property <string> secondary;
    in property <string> details;
    in property <string> action_one;
    in property <string> action_two;
    in property <string> action_three;
    in property <string> action_four;

    border-radius: 8px;
    border-width: 1px;
    border-color: #273449;
    background: #101827;

    VerticalLayout {
        padding: 18px;
        spacing: 14px;

        HorizontalLayout {
            spacing: 12px;

            VerticalLayout {
                spacing: 6px;
                Text { text: root.heading; color: #f4f7fb; font-size: 24px; }
                Text { text: root.summary; color: #9ca9bd; font-size: 13px; wrap: word-wrap; }
            }

            ActionButton { label: root.action_one; }
            ActionButton { label: root.action_two; }
            ActionButton { label: root.action_three; }
            ActionButton { label: root.action_four; }
        }

        HorizontalLayout {
            spacing: 12px;
            MetricTile { label: "Status"; value: root.status; }
            MetricTile { label: "Primary"; value: root.primary; }
            MetricTile { label: "Secondary"; value: root.secondary; }
        }

        Rectangle {
            min-height: 410px;
            border-radius: 8px;
            border-width: 1px;
            border-color: #273449;
            background: #0b1220;

            Text {
                x: 14px;
                y: 14px;
                width: parent.width - 28px;
                text: root.details;
                color: #d7e3f3;
                font-size: 13px;
                wrap: word-wrap;
            }
        }
    }
}

export component AppWindow inherits Window {
    in property <string> app_title: "Trading Bot Slint";
    in-out property <int> selected_tab: 0;

    title: app_title;
    width: 1240px;
    height: 820px;
    background: #080d16;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 74px;
            background: #0b1220;
            border-width: 0px;

            HorizontalLayout {
                padding: 18px;
                spacing: 18px;

                VerticalLayout {
                    spacing: 4px;
                    Text { text: root.app_title; color: #f4f7fb; font-size: 22px; }
                    Text { text: "Rust desktop shell mirroring Python and C++ tabs."; color: #9ca9bd; font-size: 13px; }
                }

                MetricTile { label: "Total PNL Active Positions"; value: "--"; }
                MetricTile { label: "Total PNL Closed Positions"; value: "--"; }
                MetricTile { label: "Bot Status"; value: "OFF"; }
                MetricTile { label: "Bot Active Time"; value: "--"; }
            }
        }

        Rectangle {
            height: 56px;
            background: #0d1524;
            border-width: 0px;

            HorizontalLayout {
                padding-left: 18px;
                padding-right: 18px;
                padding-top: 10px;
                padding-bottom: 10px;
                spacing: 6px;

                TabButton { label: "Dashboard"; selected: root.selected_tab == 0; clicked => { root.selected_tab = 0; } }
                TabButton { label: "Chart"; selected: root.selected_tab == 1; clicked => { root.selected_tab = 1; } }
                TabButton { label: "Positions"; selected: root.selected_tab == 2; clicked => { root.selected_tab = 2; } }
                TabButton { label: "Backtest"; selected: root.selected_tab == 3; clicked => { root.selected_tab = 3; } }
                TabButton { label: "Liquidation Heatmap"; selected: root.selected_tab == 4; clicked => { root.selected_tab = 4; } }
                TabButton { label: "Code Languages"; selected: root.selected_tab == 5; clicked => { root.selected_tab = 5; } }
            }
        }

        Rectangle {
            background: #080d16;

            VerticalLayout {
                padding: 20px;

                if root.selected_tab == 0: PageContent {
                    heading: "Dashboard";
                    summary: "Main desktop trading controls mirrored from the Python and C++ dashboards.";
                    status: "Bot Status: OFF";
                    primary: "Active PNL: --";
                    secondary: "Closed PNL: --";
                    action_one: "Start";
                    action_two: "Stop";
                    action_three: "Save Config";
                    action_four: "Load Config";
                    details: "Account & Status: API Key, API Secret Key, Mode, Theme, Account Type, Account Mode, Connector, Total USDT balance, Position Mode, Refresh Balance, Leverage, Margin Mode, Assets Mode, Time-in-Force, Indicator Source\n\nAI / LLM Settings: Enable LLM assistance, Allow public network endpoint, Provider list, Model list including qwen3:8b, Base URL / IP, API key env, API token, Use for, Reasoning / Thinking, Apply LLM Settings, Local model status, Check / Download Local Model, Remove Local Model\n\nExchange: Select exchange\nMarkets & Intervals: Symbols, Refresh Symbols, Intervals, custom interval, Add Custom Interval(s)\n\nStrategy Controls: Side, Position % of Balance, Loop Interval Override, Enable Lead Trader, Use live candle values for signals (repaints), Add-only, Allow simultaneous long & short positions, Stop Bot Without Closing Active Positions, Market Close All Active Positions On Window Close (Working in progress), Stop Loss, Stop Loss Scope, Template\n\nIndicators: Moving Average (MA), Donchian Channels (DC), Parabolic SAR (PSAR), Bollinger Bands (BB), Relative Strength Index (RSI), Volume, Stochastic RSI (SRSI), Williams %R, MACD, Ultimate Oscillator (UO), ADX, DMI, SuperTrend (ST), EMA, Stochastic Oscillator, Buy-Sell Values\n\nSymbol / Interval Overrides columns: Symbol, Interval, Indicators, Loop, Leverage, Connector, Strategy Controls, Stop-Loss\n\nDesktop Service API: Enable, Host, Port, Token, Start / Connect API, Stop API, Open Dashboard, Service API: off, Preflight: unknown, Recheck Preflight\n\nService API Integration: canonical /api/v1 dashboard, config, control_start, control_stop, backtest_run, backtest_stop, llm_config, llm_providers, llm_local_model_status, llm_local_model_start, llm_local_model_pull, llm_local_model_delete, logs, and operational_preflight routes. Python service/desktop runtime remains the trading execution owner. Rust Execution Boundary: standalone Rust trading execution supported: false; Rust shells are service clients until a native engine reaches parity with Python risk guards.\n\nFramework Parity: Tauri is the full interactive Rust desktop client. Slint is a native parity surface for the same tab, control, table, route, framework, and execution-boundary map.\n\nLogs: All Logs, Position Trigger Logs, Waiting Positions (Queue)";
                }
                if root.selected_tab == 1: PageContent {
                    heading: "Chart";
                    summary: "Chart controls mirrored from Python and C++.";
                    status: "Chart ready.";
                    primary: "Market: Futures";
                    secondary: "View: TradingView";
                    action_one: "Refresh";
                    action_two: "Open In Browser";
                    action_three: "";
                    action_four: "";
                    details: "Controls: Market, Symbol, Interval, View\nView options: TradingView, Original, TradingView Lightweight\nStatus: Total PNL Active Positions, Total PNL Closed Positions, Bot Status, Bot Active Time\nChart view stack: TradingView, Original, TradingView Lightweight";
                }
                if root.selected_tab == 2: PageContent {
                    heading: "Positions";
                    summary: "Position controls and table columns mirrored from Python and C++.";
                    status: "Bot Status: OFF";
                    primary: "Total Balance: --";
                    secondary: "Available Balance: --";
                    action_one: "Refresh Positions";
                    action_two: "Market Close ALL Positions";
                    action_three: "Clear Selected";
                    action_four: "Clear All";
                    details: "Controls: Positions View, Cumulative View, Per Trade View, Auto Row Height, Auto Column Width\nStatus: Total PNL Active Positions, Total PNL Closed Positions, Total Balance, Available Balance, Bot Status, Bot Active Time\nTable columns: Symbol, Size (USDT), Last Price (USDT), Margin Ratio, Liq Price (USDT), Margin (USDT), Quantity (Qty), PNL (ROI%), Interval, Indicator, Triggered Indicator Value, Current Indicator Value, Side, Open Time, Close Time, Stop-Loss, Status, Close";
                }
                if root.selected_tab == 3: PageContent {
                    heading: "Backtest";
                    summary: "Backtest markets, parameters, indicators, output, scanner, and results mirrored from Python and C++.";
                    status: "Backtest idle";
                    primary: "Backtest Output";
                    secondary: "Max MDD Scanner";
                    action_one: "Run Backtest";
                    action_two: "Stop";
                    action_three: "Add Selected";
                    action_four: "Add All";
                    details: "Markets: Symbol Source, Futures, Spot, Refresh, Symbols, Intervals, custom interval, Add Custom Interval(s)\nBacktest Parameters: Start Date/Time, End Date/Time, Signal Logic, MDD Logic, Margin Capital, Position % of Balance, Loop Interval Override, Stop Loss, Side, Margin Mode, Position Mode, Assets Mode, Account Mode, Connector, Leverage, Template, Max MDD Scanner, Scanner status text, Scanner best candidate summary, Pair overrides\nIndicators: same indicator list and Buy-Sell Values buttons as Dashboard\nBacktest Output: Run Backtest, Stop, Add Selected to Dashboard, Add All to Dashboard, scanner request polling until idle, best max-drawdown row selection, duplicate-safe dashboard import\nResults columns: Symbol, Interval, Logic, Indicators, Trades, Loop Interval, Start Date, End Date, Position % Of Balance, Stop-Loss Options, Margin Mode (Futures), Position Mode, Assets Mode, Account Mode, Leverage (Futures), ROI (USDT), ROI (%), Max Drawdown During Position (USDT), Max Drawdown During Position (%), Max Drawdown Results (USDT), Max Drawdown Results (%)";
                }
                if root.selected_tab == 4: PageContent {
                    heading: "Liquidation Heatmap";
                    summary: "Provider tabs mirrored from Python and C++.";
                    status: "Web panels";
                    primary: "Coinglass Heatmap";
                    secondary: "Hyperliquid Map";
                    action_one: "Open in Browser";
                    action_two: "Reload";
                    action_three: "Go";
                    action_four: "";
                    details: "Coinglass Heatmap: Model 1, Model 2, Model 3\nCoinank\nBitcoin Counterflow\nHyblock Capital\nCoinglass Map\nHyperliquid Map\nEach panel has URL, Go, Open in Browser, and Reload controls.";
                }
                if root.selected_tab == 5: PageContent {
                    heading: "Code Languages";
                    summary: "Language, Rust framework, and environment version controls mirrored from Python and C++.";
                    status: "0 selected";
                    primary: "Language: Rust";
                    secondary: "Framework: Tauri";
                    action_one: "Update Selected";
                    action_two: "Update All";
                    action_three: "Check Versions";
                    action_four: "Refresh Env Versions";
                    details: "Choose your language: Python, C++, Rust\nChoose your Rust framework: Tauri full interactive client, Slint native parity surface, egui shared-catalog parity surface, Iced shared-catalog parity surface, Dioxus Desktop shared-catalog parity surface\nNative Rust Runtime Gap: Native Rust trading runtime ready: false. C++ has BinanceRestClient, BinanceWsClient, dashboard runtime lifecycle, positions sync, futures order submission, and risk/shutdown experiments. Rust currently has Service API clients, tab/catalog parity, LLM/provider catalogs, and desktop shells. Before enabling Rust native trading: add REST market data, WebSocket streams, signed account/position snapshots, order submission, runtime lifecycle, and risk/shutdown guards.\nEnvironment Versions columns: Select, Dependency, Installed, Latest, Usage, Usage Change Counter\nDependency rows include rustc, cargo, Trading Bot Rust workspace, trading-bot-core, trading-bot-contracts, and the selected framework package.\n\nService API Integration: Tauri can launch apps/service-api/main.py --serve locally; all Rust shells surface the same canonical /api/v1 backend contract and keep Python as strategy, risk, and exchange execution owner. Framework Parity: Tauri is full interactive; Slint, egui, Iced, and Dioxus Desktop mirror the same tab/control/route option map for evaluation. Rust Execution Boundary: standalone Rust trading execution supported: false.";
                }
            }
        }

        Rectangle {
            height: 42px;
            background: #0b1220;
            border-width: 0px;

            HorizontalLayout {
                padding-left: 18px;
                padding-right: 18px;
                spacing: 18px;
                Text { text: "Total PNL Active Positions: --"; color: #dbeafe; font-size: 13px; }
                Text { text: "Total PNL Closed Positions: --"; color: #dbeafe; font-size: 13px; }
                Text { text: "Bot Status: OFF"; color: #ef4444; font-size: 13px; }
                Text { text: "Bot Active Time: --"; color: #dbeafe; font-size: 13px; }
            }
        }
    }
}
